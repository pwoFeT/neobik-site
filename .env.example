# ─────────────────────────────────────────
# NEOBIK — Variables d'environnement
# Copier ce fichier en .env.local pour le développement
# Sur Coolify : ajouter ces variables dans l'interface "Environment Variables"
# ─────────────────────────────────────────

# URL publique du site (pas de slash final)
NEXT_PUBLIC_SITE_URL=https://neobik.com

# Email de contact principal
CONTACT_EMAIL=contact@neobik.com

# Brevo (Sendinblue) — Récupérer sur brevo.com → Mon compte → SMTP & API → Clés API
BREVO_API_KEY=VOTRE_CLE_API_BREVO

# ID de la liste newsletter dans Brevo (Contacts → Listes)
BREVO_LIST_ID=2

# Crisp Chat — Récupérer sur app.crisp.chat → Réglages → Intégrations → Identifiant du site
# Laisser vide pour désactiver le chat
NEXT_PUBLIC_CRISP_WEBSITE_ID=a947c765-77eb-4e2b-b1db-963f5214dc81

# Google Search Console — code de vérification (meta tag)
GOOGLE_SITE_VERIFICATION=

# Keystatic — En production, mettre 'github' si vous voulez éditer via GitHub
# En local et sur VPS : laisser 'local'
KEYSTATIC_STORAGE=local
